<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="Yum Inventory" Manufacturer="Yasu Solutions" Version="1.0.0" UpgradeCode="12345678-1234-1234-1234-123456789012">
    <MajorUpgrade DowngradeErrorMessage="A newer version is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Directory Id="ProgramFiles6432Folder">
      <Directory Id="ManufacturerFolder" Name="Yasu Solutions">
        <Directory Id="INSTALLFOLDER" Name="Yum Inventory" />
      </Directory>
    </Directory>

    <DirectoryRef Id="INSTALLFOLDER">
      <Component GroupRef="AppFiles" />
    </DirectoryRef>

    <Feature Id="MainFeature">
      <ComponentGroupRef Id="AppFiles" />
    </Feature>
  </Package>
</Wix>
